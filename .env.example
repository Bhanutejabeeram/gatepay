# Telegram bot — get from @BotFather
TELEGRAM_BOT_TOKEN=

# Public base URL of this server (used for KIRAPAY redirectUrl + subscribe links)
# In dev: ngrok URL, e.g. https://abc-12-34.ngrok-free.app
PUBLIC_BASE_URL=http://localhost:3000

# Bot's Telegram username (without @) — used to build deep-link redirects
BOT_USERNAME=

# KIRAPAY — get API key from https://dashboard.kira-pay.com after onboarding
KIRAPAY_API_KEY=
KIRAPAY_BASE_URL=https://api.kira-pay.com/api

# Webhook secret — registered with KIRAPAY and verified on inbound webhooks
KIRAPAY_WEBHOOK_SECRET=

# Solana settlement wallet — where SOL lands. Owner sets per-channel, but this is the bot's default
DEFAULT_SETTLEMENT_ADDRESS=
DEFAULT_SETTLEMENT_CHAIN_ID=sol
DEFAULT_SETTLEMENT_TOKEN_ADDRESS=SOL

# Neon Postgres — get from console.neon.tech
DATABASE_URL=

# Server
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
